# Ollama configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2

# Models (pulled automatically on first run)
MODEL_REASONING=qwen2.5:14b-instruct-q4_K_M
MODEL_VERIFICATION=phi4:14b-q4_K_M
MODEL_ROUTING=llama3.2:3b-instruct-q4_K_M
MODEL_EMBEDDING=nomic-embed-text
MODEL_RERANKER=BAAI/bge-reranker-v2-m3
MODEL_RERANKER_FAST=cross-encoder/ms-marco-MiniLM-L-6-v2
MITORAG_LOAD_RERANKER_MODEL=0

# Biomedical embedding (via sentence-transformers, not Ollama)
BIO_EMBED_MODEL=NeuML/pubmedbert-base-embeddings

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mitorag_local

# Paper folder (user configurable)
PAPERS_DIR=./data/papers

# Vector store
VECTOR_STORE=chromadb
CHROMA_DIR=./data/chroma

# Scientific web search
MITORAG_ENABLE_LIVE_WEB=0
NCBI_EMAIL=user@example.com
NCBI_API_KEY=
S2_API_KEY=
REDIS_URL=redis://localhost:6379/0
